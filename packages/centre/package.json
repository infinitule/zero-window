{
  "name": "@zw/centre",
  "version": "1.0.0",
  "description": "ZERO-WINDOW centre node: bundle custody, offline admit verification, deterministic paper generation, IPP printing, autonomy mode",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "zw-centre": "./dist/cli.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@zw/authority": "workspace:*",
    "@zw/ca": "workspace:*",
    "@zw/crypto": "workspace:*",
    "@zw/kms-vault": "workspace:*",
    "@zw/log": "workspace:*",
    "@zw/ops": "workspace:*",
    "better-sqlite3": "^11.7.0",
    "ipp": "^2.0.1",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.17.0",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "license": "Apache-2.0"
}
